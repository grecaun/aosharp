<?xml version="1.0" standalone="yes"?>
<root>
	<View view_layout="vertical" name="parent">
		<BorderView v_alignment="TOP" h_alignment="CENTER" view_layout="vertical" name="Settings" layout_borders="Rect(5,5,5,5)" max_size="Point(16000,-1)">

			<Button name="InfoView" label="Info" layout_borders="Rect(5,5,5,5)"/>
			<BitmapView bitmap_id="GFX_GUI_FRIENDLIST_SPLITTER" layout_borders="Rect(5,5,5,5)"/>
			<TextView value="PRESS INFO BUTTON" font="Large" layout_borders="Rect(5,5,5,5)" color="0x00FF0000"/>

			<Button name="Enable_Disable_Button" label="" layout_borders="Rect(5,5,3,5)"/>
			<Button name="TeamButton" label="" layout_borders="Rect(5,5,3,5)"/>

			<Button name="KittingButton" label="Kits" layout_borders="Rect(5,5,3,5)"/>

			<BitmapView bitmap_id="GFX_GUI_FRIENDLIST_SPLITTER" layout_borders="Rect(5,5,5,5)"/>

			<View view_layout="center">
				<TextView layout_borders="Rect(0,0,0,0)"/>
				<OptionCheckBox label="Tank/Leader" opt_category="AOSharp" opt_type="variant" opt_variable="AutomatonInf__Tank" layout_borders="Rect(10,1,5,1)"/>
				<OptionCheckBox label="Path to corpse(looting)" opt_category="AOSharp" opt_type="variant" opt_variable="AutomatonInf__Looting" layout_borders="Rect(10,1,5,1)"/>
				<OptionCheckBox label="Stop after mission" opt_category="AOSharp" opt_type="variant" opt_variable="AutomatonInf__Stop" layout_borders="Rect(10,1,5,1)"/>

				<OptionCheckBox label="(Omni) Double reward" opt_category="AOSharp" opt_type="variant" opt_variable="AutomatonInf__DoubleReward" layout_borders="Rect(10,1,5,1)"/>
				<OptionCheckBox label="Leech" opt_category="AOSharp" opt_type="variant" opt_variable="AutomatonInf__Leech" layout_borders="Rect(10,1,5,1)"/>

			</View>

			<BorderView v_alignment="TOP" h_alignment="CENTER" view_layout="vertical" name="BroadcastSettings" layout_borders="Rect(0,5,0,0)" max_size="Point(16000,-1)">
				<Button name="BroadcastToggles" label="Broadcast Settings" layout_borders="Rect(0,5,0,5)"/>
				<BitmapView bitmap_id="GFX_GUI_FRIENDLIST_SPLITTER" layout_borders="Rect(0,0,0,0)"/>
				<View view_layout="center">
					<TextView layout_borders="Rect(0,0,0,0)"/>
					<OptionCheckBox label="Clear mission before sharting " opt_category="AOSharp" opt_type="variant" opt_variable="AutomatonInf__Clear" layout_borders="Rect(0,0,5,5)"/>
					<BitmapView bitmap_id="GFX_GUI_FRIENDLIST_SPLITTER" layout_borders="Rect(0,0,0,5)"/>
					<OptionRadioButtonGroup label="Mode" h_alignment="LEFT" layout_borders="Rect(10,1,5,1)" opt_type="variant" opt_variable="AutomatonInf__ModeSelection">
						<RadioButton label="Defend (slow)" value="0"/>
						<RadioButton label="Roam (fast)" value="1"/>
					</OptionRadioButtonGroup>
				</View>

				<BitmapView bitmap_id="GFX_GUI_FRIENDLIST_SPLITTER" layout_borders="Rect(5,5,5,5)"/>

				<View v_alignment="TOP" h_alignment="LEFT" view_layout="horizontal" layout_borders="Rect(5,5,5,5)" max_size="Point(16000,-1)">
					<OptionRadioButtonGroup label="Faction" h_alignment="LEFT" layout_borders="Rect(10,1,1,1)" opt_type="variant" opt_variable="AutomatonInf__FactionSelection">
						<RadioButton label="Neutral" value="0"/>
						<RadioButton label="Clan" value="1"/>
						<RadioButton label="Omni" value="2"/>
					</OptionRadioButtonGroup>
					<OptionRadioButtonGroup label="Difficulty" h_alignment="LEFT" layout_borders="Rect(10,1,1,1)" opt_type="variant" opt_variable="AutomatonInf__DifficultySelection">
						<RadioButton label="Easy" value="0"/>
						<RadioButton label="Medium" value="1"/>
						<RadioButton label="Hard" value="2"/>
					</OptionRadioButtonGroup>
				</View>
			</BorderView>

			<View view_layout="center">
				<View name="Errors" view_layout="vertical" v_alignment="TOP" h_alignment="center" layout_borders="Rect(0,0,0,0)" max_size="Point(16000,-1)">
					<Haxxor/>
				</View>
			</View>

			<BitmapView bitmap_id="GFX_GUI_FRIENDLIST_SPLITTER" layout_borders="Rect(5,5,5,5)"/>
			<TextView name="State" value="" layout_borders="Rect(0,0,0,2)"/>
			<BitmapView bitmap_id="GFX_GUI_FRIENDLIST_SPLITTER" layout_borders="Rect(5,5,5,5)"/>
			<TextView name="Counter" value="" layout_borders="Rect(0,0,0,2)"/>
			<BitmapView bitmap_id="GFX_GUI_FRIENDLIST_SPLITTER" layout_borders="Rect(5,5,5,5)"/>
			<TextView name="LastRunTime" value="" layout_borders="Rect(0,0,0,2)"/>
			<BitmapView bitmap_id="GFX_GUI_FRIENDLIST_SPLITTER" layout_borders="Rect(5,5,5,5)"/>
			<TextView name="RunTime" value="" layout_borders="Rect(0,0,0,2)"/>
			<BitmapView bitmap_id="GFX_GUI_FRIENDLIST_SPLITTER" layout_borders="Rect(5,5,5,5)"/>
			<TextView name="VersionNumber" value="" layout_borders="Rect(0,0,0,2)"/>
			<BitmapView bitmap_id="GFX_GUI_FRIENDLIST_SPLITTER" layout_borders="Rect(5,5,5,5)"/>
		</BorderView>
	</View>
</root>