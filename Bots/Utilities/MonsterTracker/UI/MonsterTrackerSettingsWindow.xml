<?xml version="1.0" encoding="utf-8" ?>
<root>
	<BorderView v_alignment="TOP" h_alignment="Center" view_layout="vertical" name="Settings" layout_borders="Rect(0,0,0,0)" max_size="Point(16000,-1)">
		<Button name="Enable_Disable_Button"  layout_borders="Rect(0,5,0,5)"/>
		<BitmapView bitmap_id="GFX_GUI_FRIENDLIST_SPLITTER" layout_borders="Rect(0,5,0,5)"/>
		<Button name="FollowButton" layout_borders="Rect(0,5,0,5)"/>
		<BorderView v_alignment="TOP" h_alignment="LEFT" view_layout="vertical" name="Settings2" layout_borders="Rect(5,2,5,10)" min_size="Point(0,200)">
			<View layout_borders="Rect(0,5,0,5)">
				<ScrollView h_alignment="LEFT" label="#Behaviour/s" v_scrollbar_mode="auto" scroll_client="behaviour_s_scroll" layout_borders="Rect(5,5,5,5)">
					<ScrollViewChild name="behaviour_s_scroll" layout_borders="Rect(0,0,0,0)">
						<View name="ScrollListView">
							<Haxxor/>
						</View>
						<VLayoutSpacer/>
					</ScrollViewChild>
				</ScrollView>
			</View>
		</BorderView>

		<Button name="OpenFolder" Label ="Open folder" layout_borders="Rect(0,5,0,5)"/>
		
		<View view_layout="center">
			<View name="Errors" view_layout="vertical" v_alignment="TOP" h_alignment="center" layout_borders="Rect(0,0,0,0)" max_size="Point(16000,-1)">
				<Haxxor/>
			</View>
		</View>

		<BitmapView bitmap_id="GFX_GUI_FRIENDLIST_SPLITTER" layout_borders="Rect(0,5,0,5)"/>

		<TextView name="VersionNumber" value="" layout_borders="Rect(0,5,0,5)"/>
	</BorderView>
</root>